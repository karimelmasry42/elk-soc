# ELK stack versions — keep these in lock-step with the Beats installed on endpoints.
ELASTIC_VERSION=8.15.0

# JVM heap sizes. Elasticsearch needs ~2x heap as container memory, so 2g heap → 4g container.
# Lower these if the demo host has < 8 GB RAM.
ES_JAVA_OPTS=-Xms2g -Xmx2g
LOGSTASH_JAVA_OPTS=-Xms512m -Xmx512m

# Internal Docker network for ELK services. Change only if it conflicts with your LAN.
ELK_NETWORK_SUBNET=172.20.0.0/16
